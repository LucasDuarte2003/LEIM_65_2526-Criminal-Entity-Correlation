ual"},{"value":{"start":1460,"end":1482,"text":"exploração do trabalho","labels":["CRIME"]},"id":"jOQw8xOfxs","from_name":"label","to_name":"text","type":"labels","origin":"manual"},{"value":{"start":1485,"end":1511,"text":"auxílio à imigração ilegal","labels":["CRIME"]},"id":"wMpuhnJcJZ","from_name":"label","to_name":"text","type":"labels","origin":"manual"}],"was_cancelled":false,"ground_truth":false,"created_at":"2026-04-03T15:17:25.581815Z","updated_at":"2026-04-03T15:17:25.581815Z","draft_created_at":null,"lead_time":237.324,"prediction":{},"result_count":0,"unique_id":"a833b84c-5caa-4b04-afb1-6ab18cab1551","import_id":9,"last_action":null,"bulk_created":false,"task":34,"project":4,"updated_by":null,"parent_prediction":null,"parent_annotation":null,"last_created_by":null}],"file_upload":"3b552414-noticas_anotadas_afonso.json","drafts":[],"predictions":[],"data":{"text":"Évora, 28 de março de 2024. — O Serviço de Estrangeiros e Fronteiras, em coordenação com a Guarda Nacional Republicana de Évora, deteve três suspeitos no âmbito da Operação Campo Livre, dirigida a uma rede de tráfico de trabalhadores estrangeiros explorados em explorações agrícolas do Alentejo. Os detidos são Nuno Alexandre Duarte Carriço, de 45 anos, natural de Évora, Piotr Marek Wiśniewski, de 37 anos, de nacionalidade polaca, e Anabela Conceição Ferreira Dias, de 40 anos, natural de Beja. A rede recrutava trabalhadores vulneráveis na Roménia, Moldávia e Ucrânia através de anúncios falsos, transportando-os posteriormente em duas viaturas: uma carrinha Volkswagen Transporter com a matrícula 93-DH-52 e um Ford Transit com a matrícula 16-WT-39. As comunicações de recrutamento eram feitas através do endereço de email nuno.carriço.agro@gmail.com e do telemóvel 961 374 820, utilizado por Nuno Carriço. Piotr Wiśniewski utilizava o número 929 841 653 para coordenar as chegadas das vítimas em território nacional. As vítimas, em número estimado de 34, eram obrigadas a trabalhar 14 horas diárias em condições degradantes, recebendo salários muito inferiores ao acordado, quando recebiam. O prejuízo causado às vítimas em salários não pagos foi estimado em 87 000 euros. O Tribunal Judicial de Évora decretou prisão preventiva para Nuno Carriço e Piotr Wiśniewski e prisão domiciliária para Anabela Dias. Os três respondem por tráfico de seres humanos, exploração do trabalho e auxílio à imigração ilegal.","original_id":"SIN-009"},"meta":{},"created_at":"2026-04-03T15:17:25.569215Z","updated_at":"2026-04-03T15:17:25.569215Z","allow_skip":true,"inner_id":9,"total_annotations":1,"cancelled_annotations":0,"total_predictions":0,"comment_count":0,"unresolved_comment_count":0,"last_comment_updated_at":null,"project":4,"updated_by":null,"comment_authors":[]},{"id":35,"annotations":[{"id":28,"completed_by":1,"result":[{"value":{"start":0,"end":5,"text":"Braga","labels":["LOCAL"]},"id":"vncQa21GSl","from_name":"label","to_name":"text","type":"labels","origin":"manual"},{"value":{"start":7,"end":25,"text":"6 de abril de 2024","labels":["DATA"]},"id":"8o4GxtlbL6","from_name":"label","to_name":"text","type":"labels","origin":"manual"},{"value":{"start":31,"end":64,"text":"Autoridade Tributária e Aduaneira","labels":["ORGANIZACAO"]},"id":"0BSERbiNBb","from_name":"label","to_name":"text","type":"labels","origin":"manual"},{"value":{"start":87,"end":129,"text":"Departamento de Investigação e Ação Penal ","labels":["ORGANIZACAO"]},"id":"yZFYkpCK99","from_name":"label","to_name":"text","type":"labels","origin":"manual"},{"value":{"start":132,"end":137,"text":"Braga","labels":["LOCAL"]},"id":"O_RY846_PF","from_name":"label","to_name":"text","type":"labels","origin":"manual"},{"value":{"start":232,"end":245,"text":"fraude fiscal","labels":["CRIME"]},"id":"0CGufOHhvr","from_name":"label","to_name":"text","type":"labels","origin":"manual"},{"value":{"start":248,"end":290,"text":"evasão de capitais através de criptomoedas","labels":["CRIME"]},"id":"8kCYkIus-N","from_name":"label","to_name":"text