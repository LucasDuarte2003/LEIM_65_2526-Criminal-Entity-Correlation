abels":["CRIME"]},"id":"piVjQDE1Ld","from_name":"label","to_name":"text","type":"labels","origin":"manual"},{"value":{"start":1329,"end":1349,"text":"associação criminosa","labels":["CRIME"]},"id":"yr9OmosYvs","from_name":"label","to_name":"text","type":"labels","origin":"manual"}],"was_cancelled":false,"ground_truth":false,"created_at":"2026-04-03T15:17:25.581815Z","updated_at":"2026-04-03T15:17:25.581815Z","draft_created_at":null,"lead_time":760.375,"prediction":{},"result_count":0,"unique_id":"5b43df5b-1fde-4046-95aa-a6ad9bcd6545","import_id":8,"last_action":null,"bulk_created":false,"task":33,"project":4,"updated_by":null,"parent_prediction":null,"parent_annotation":null,"last_created_by":null}],"file_upload":"3b552414-noticas_anotadas_afonso.json","drafts":[],"predictions":[],"data":{"text":"Aveiro, 11 de março de 2024. — O Núcleo de Investigação Criminal da PSP de Aveiro desmantelou um grupo especializado no furto de viaturas e extorsão que operava na região de Aveiro e Viseu desde junho de 2023. Foram detidos Armando José Pereira Gomes, de 32 anos, natural de Aveiro, e Diogo Filipe Monteiro Santos, de 26 anos, natural de Viseu, no dia 8 de março de 2024. Segundo a investigação, os dois arguidos furtavam viaturas de luxo por encomenda, utilizando inibidores de sinal para contornar os sistemas de alarme. Entre as viaturas recuperadas contam-se um BMW X5 com a matrícula 28-YH-64, um Audi Q7 com a matrícula 51-NM-07 e um Mercedes-Benz GLE com a matrícula 39-KP-76. Após os furtos, os arguidos contactavam os proprietários através dos números de telemóvel 938 274 561, utilizado por Armando Gomes, e 915 863 429, utilizado por Diogo Santos, exigindo o pagamento de resgates que variavam entre 3 000 e 20 000 euros para devolução das viaturas. As investigações revelaram que o grupo tinha contactos com receptadores em Espanha, para onde eram exportadas as viaturas não resgatadas. O prejuízo total causado às vítimas foi estimado em 310 000 euros. O Tribunal Judicial de Aveiro decretou prisão preventiva para ambos os arguidos. Armando Gomes e Diogo Santos respondem por furto qualificado, extorsão agravada e associação criminosa.","original_id":"SIN-008"},"meta":{},"created_at":"2026-04-03T15:17:25.569215Z","updated_at":"2026-04-03T15:17:25.569215Z","allow_skip":true,"inner_id":8,"total_annotations":1,"cancelled_annotations":0,"total_predictions":0,"comment_count":0,"unresolved_comment_count":0,"last_comment_updated_at":null,"project":4,"updated_by":null,"comment_authors":[]},{"id":34,"annotations":[{"id":27,"completed_by":1,"result":[{"value":{"start":0,"end":5,"text":"Évora","labels":["LOCAL"]},"id":"GNm5CFY97m","from_name":"label","to_name":"text","type":"labels","origin":"manual"},{"value":{"start":7,"end":26,"text":"28 de março de 2024","labels":["DATA"]},"id":"NP_D7W-5X8","from_name":"label","to_name":"text","type":"labels","origin":"manual"},{"value":{"start":32,"end":68,"text":"Serviço de Estrangeiros e Fronteiras","labels":["ORGANIZACAO"]},"id":"FF_Js4BsLs","from_name":"label","to_name":"text","type":"labels","origin":"manual"},{"value":{"start":91,"end":118,"text":"Guarda Nacional Republicana","labels":["ORGANIZACAO"]},"id":"-V2gEIXmnu","from_name":"label","to_name":"text","type":"labels","origin":"manual"},{"value":{"start":122,"end":127,"text":"Évora","labels":["LOCAL"]},"id":"4OXu3yjrxj","from_name":"label","to_name":"text","type":"labels","origin":"manual"},{"value":{"start":209,"end":282,"text":"tráfico de trabalhadores estrangeiros explorados em explorações agrícolas","labels":["CRIME"]},"id":"OKiPfwYzWx","from_name":"label","to_name":"text","type":"labels","origin":"manual"},{"value":{"start":286,"end":294,"text":"Alentejo","labels":["LOCAL"]},"id":"jyqLc-_FRO","from_name":"label","to_name":"text","type":"labels","origin":"manual"},{"value":{"start":311,"end":340,"text":"Nuno Alexandre Duarte Carriço","labels":["PESSOA"]},"id":"um4SPUJTTF","from_name":"label","to_name":"text","type":"labels","origin":"manual"},{"value"